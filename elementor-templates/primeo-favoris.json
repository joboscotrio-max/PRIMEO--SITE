{
    "title": "PRIMEO - Favoris",
    "type": "page",
    "version": "0.4",
    "page_settings": {
        "template": "elementor_canvas"
    },
    "content": [
        {
            "elType": "section",
            "settings": {
                "layout": "full_width",
                "padding": {
                    "unit": "px",
                    "top": "10",
                    "right": "0",
                    "bottom": "10",
                    "left": "0"
                },
                "background_background": "classic",
                "background_color": "#000"
            },
            "elements": [
                {
                    "elType": "column",
                    "settings": {
                        "_column_size": 100
                    },
                    "elements": [
                        {
                            "elType": "widget",
                            "widgetType": "html",
                            "settings": {
                                "html": "<div style='overflow:hidden;'><div style='display:inline-flex;gap:6rem;animation:marquee 25s linear infinite;color:#fff;font-size:12px;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;'><span>✓ LIVRAISON GRATUITE DÈS 99$</span><span>✓ QUALITÉ PREMIUM</span><span>✓ LIVRAISON GRATUITE DÈS 99$</span><span>✓ QUALITÉ PREMIUM</span></div></div><style>@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}</style>"
                            }
                        }
                    ]
                }
            ]
        },
        {
            "elType": "section",
            "settings": {
                "layout": "boxed",
                "padding": {
                    "unit": "px",
                    "top": "50",
                    "right": "0",
                    "bottom": "80",
                    "left": "0"
                }
            },
            "elements": [
                {
                    "elType": "column",
                    "settings": {
                        "_column_size": 100
                    },
                    "elements": [
                        {
                            "elType": "widget",
                            "widgetType": "heading",
                            "settings": {
                                "title": "Mes Favoris",
                                "header_size": "h1",
                                "typography_typography": "custom",
                                "typography_font_family": "Albert Sans",
                                "typography_font_size": {
                                    "unit": "px",
                                    "size": 32
                                },
                                "typography_font_weight": "800"
                            }
                        },
                        {
                            "elType": "widget",
                            "widgetType": "html",
                            "settings": {
                                "html": "<div style='border:1px solid #ebebeb;border-radius:10px;padding:40px;text-align:center;margin-top:20px;'><div style='font-size:64px;margin-bottom:16px;'>♡</div><h3 style='font-size:20px;font-weight:700;margin-bottom:12px;'>Aucun favori pour le moment</h3><p style='font-size:14px;color:#868686;margin-bottom:24px;'>Parcourez nos collections et ajoutez vos produits préférés à votre liste de favoris.</p><a href='/collections' style='display:inline-block;padding:14px 36px;background:#000;color:#fff;font-size:13px;font-weight:600;text-transform:uppercase;border-radius:4px;text-decoration:none;'>Découvrir les collections</a></div>"
                            }
                        },
                        {
                            "elType": "widget",
                            "widgetType": "html",
                            "settings": {
                                "html": "<div style='background:#f5f5f5;border-radius:10px;padding:24px;margin-top:30px;'><p style='font-size:13px;color:#868686;text-align:center;'>💡 <strong>Note :</strong> Installez un plugin Wishlist (ex: YITH WooCommerce Wishlist) pour gérer dynamiquement les favoris.</p></div>"
                            }
                        }
                    ]
                }
            ]
        }
    ]
}